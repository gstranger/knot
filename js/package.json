{
  "name": "knot-cad",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript/React bindings for the Knot NURBS CAD kernel",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./graph": {
      "import": "./dist/graph/index.js",
      "types": "./dist/graph/index.d.ts"
    },
    "./math": {
      "import": "./dist/math/index.js",
      "types": "./dist/math/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "knot-wasm": "workspace:*"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "three": ">=0.150"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": { "optional": true },
    "react": { "optional": true },
    "three": { "optional": true }
  },
  "devDependencies": {
    "@react-three/fiber": "^8.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/three": "^0.170.0",
    "react": "^18.3.0",
    "three": "^0.170.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
